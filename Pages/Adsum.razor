        pdfModalUrl = "";
    }

    private async Task IrAlForo() => await JS.InvokeVoidAsync("scrollToElement", "foro-section");

    public void Dispose()
    {
        _timerReloj?.Stop();
        _timerReloj?.Dispose();

        _timerCapitalario?.Stop();
        _timerCapitalario?.Dispose();

        _timerForo?.Stop();
        _timerForo?.Dispose();

        _timerLoading?.Stop();
        _timerLoading?.Dispose();

        _toastCts?.Cancel();
        _toastCts?.Dispose();
    }

    private async Task MostrarToastAsync(string titulo, string mensaje, string tipo = "success", string icono = "check_circle", bool autoClose = true, int duration = 3200)
    {
        _toastCts?.Cancel();
        _toastCts?.Dispose();
        _toastCts = new CancellationTokenSource();

        ToastTitulo = titulo;
        ToastMensaje = mensaje;
        ToastTipo = tipo;
        ToastIcono = icono;
        ToastSaliendo = false;
        MostrarToast = true;

        await InvokeAsync(StateHasChanged);

        if (!autoClose)
            return;

        try
        {
            await Task.Delay(duration, _toastCts.Token);

            if (!_toastCts.Token.IsCancellationRequested)
                await OcultarToast();
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task OcultarToast()
    {
        if (!MostrarToast)
            return;

        ToastSaliendo = true;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(220);

        MostrarToast = false;
        ToastSaliendo = false;
        await InvokeAsync(StateHasChanged);
    }

    private string GetSafePdfUrl(string? rawUrl)
    {
        if (string.IsNullOrWhiteSpace(rawUrl))
            return "";

        var url = rawUrl.Trim().Replace("\\", "/");

        if (url.StartsWith("data:application/pdf", StringComparison.OrdinalIgnoreCase))
            return "";

        if (url.StartsWith("file:///", StringComparison.OrdinalIgnoreCase))
            url = url.Replace("file:///", "/");

        if (Uri.TryCreate(url, UriKind.Absolute, out var absoluta))
        {
            if (absoluta.Scheme == Uri.UriSchemeHttp || absoluta.Scheme == Uri.UriSchemeHttps)
                return absoluta.ToString();
        }

        url = url.TrimStart('~');

        if (!url.StartsWith("/"))
            url = "/" + url;

        return NavManager.ToAbsoluteUri(url).ToString();
    }
