   private async Task GuardarSponsor()
{
    if (string.IsNullOrWhiteSpace(nuevoSponsor.Nombre))
        return;

    if (string.IsNullOrWhiteSpace(nuevoSponsor.ImagenUrl))
        return;

    nuevoSponsor.Nombre = nuevoSponsor.Nombre.Trim();
    nuevoSponsor.Link = (nuevoSponsor.Link ?? "").Trim();
    nuevoSponsor.ImagenUrl = nuevoSponsor.ImagenUrl.Trim().Replace("\\", "/");

    if (nuevoSponsor.ImagenUrl.StartsWith("/images/", StringComparison.OrdinalIgnoreCase))
        nuevoSponsor.ImagenUrl = nuevoSponsor.ImagenUrl.Replace("/images/", "", StringComparison.OrdinalIgnoreCase);

    if (nuevoSponsor.ImagenUrl.StartsWith("images/", StringComparison.OrdinalIgnoreCase))
        nuevoSponsor.ImagenUrl = nuevoSponsor.ImagenUrl.Replace("images/", "", StringComparison.OrdinalIgnoreCase);

    bool ok = string.IsNullOrEmpty(sponsorEditKey)
        ? await Firebase.Agregar("sponsors", nuevoSponsor)
        : await Firebase.ActualizarObjeto("sponsors", sponsorEditKey, nuevoSponsor);

    if (ok)
    {
        await Firebase.LimpiarCache("sponsors");
        LimpiarSponsor();
        await CargarSponsors(0);
    }
}

