    private string GetSponsorImage(string? imagen)
{
    if (string.IsNullOrWhiteSpace(imagen))
        return "/img/LogoAdsum-Claro.png";

    var limpia = imagen.Trim().Replace("\\", "/");

    if (limpia.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        limpia.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        return limpia;

    limpia = limpia.TrimStart('/');

    if (limpia.StartsWith("img/", StringComparison.OrdinalIgnoreCase))
        return "/" + limpia;

    return $"/img/{limpia}";
}

    private async Task CargarTodo(int cacheSegundos = 0)
    {
        await Task.WhenAll(
            CargarForo(cacheSegundos),
            CargarReflexiones(cacheSegundos),
            CargarPueblo(cacheSegundos),
            CargarSponsors(cacheSegundos),
            CargarHistoricos(cacheSegundos),
            CargarColaborar(cacheSegundos)
        );
    }

    private async Task CargarForo(int cache = 0)
{
    try
    {
        var pendientes = await Firebase.ObtenerDiccionario<Intencion>(NodeIntencionesPendientes, cache);
        var publicadas = await Firebase.ObtenerDiccionario<Intencion>(NodeIntencionesPublicadas, cache);

        intenciones = pendientes?
            .Where(k => k.Value != null && !string.Equals(k.Key, "init", StringComparison.OrdinalIgnoreCase))
            .Select(k => new IntencionItem
            {
                Key = k.Key,
                Id = k.Value.Id,
                Nombre = k.Value.Nombre,
                Texto = k.Value.Texto,
                Fecha = k.Value.Fecha,
                Rezos = k.Value.Rezos
            })
            .OrderByDescending(x => x.Fecha)
            .ToList() ?? new List<IntencionItem>();

        intencionesPublicadas = publicadas?
            .Where(k => k.Value != null && !string.Equals(k.Key, "init", StringComparison.OrdinalIgnoreCase))
            .Select(k => new IntencionItem
            {
                Key = k.Key,
                Id = k.Value.Id,
                Nombre = k.Value.Nombre,
                Texto = k.Value.Texto,
                Fecha = k.Value.Fecha,
                Rezos = k.Value.Rezos
            })
            .OrderByDescending(x => x.Fecha)
            .ToList() ?? new List<IntencionItem>();

        StateHasChanged();
    }
    catch
    {
    }
}

