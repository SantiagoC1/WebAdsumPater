    private void AgregarSlot(int i)
    {
        puebloConfig.Cronograma ??= new List<DiaCrono>();

        if (i >= 0 && i < puebloConfig.Cronograma.Count)
        {
            puebloConfig.Cronograma[i].Actividades ??= new List<Slot>();
            puebloConfig.Cronograma[i].Actividades.Add(new Slot());
        }
    }

    private void EliminarSlot(int d, int s)
    {
        if (puebloConfig.Cronograma == null || d < 0 || d >= puebloConfig.Cronograma.Count)
            return;

        var dia = puebloConfig.Cronograma[d];
        if (dia.Actividades != null && s >= 0 && s < dia.Actividades.Count)
            dia.Actividades.RemoveAt(s);
    }

