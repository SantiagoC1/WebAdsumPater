    private async Task LoginConGoogle()
{
    showError = false;
    emailIntentado = "";

    try
    {
        var user = await JS.InvokeAsync<GoogleUser>("googleLogin");

        Console.WriteLine($"Login user null? {user == null}");
        Console.WriteLine($"Login email: {user?.Email}");
        Console.WriteLine($"Login displayName: {user?.DisplayName}");

        var email = NormalizarEmail(user?.Email);

        if (user != null && EsAdminHabilitado(email))
        {
            isLogged = true;
            adminNombre = string.IsNullOrWhiteSpace(user.DisplayName) ? email : user.DisplayName;

            await JS.InvokeVoidAsync("localStorage.setItem", "adsumUserEmail", email);
            await JS.InvokeVoidAsync("localStorage.setItem", "adsumUserNombre", adminNombre);

            await CargarTodo(0);
        }
        else
        {
            showError = true;
            emailIntentado = user?.Email ?? "(sin email devuelto)";
            await JS.InvokeVoidAsync("googleLogout");
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error en LoginConGoogle: {ex.Message}");
        showError = true;
        emailIntentado = "(error JS / popup)";
    }
}

    private async Task Logout()
{
    isLogged = false;
    adminNombre = "";
    showError = false;

    await JS.InvokeVoidAsync("googleLogout");
    await JS.InvokeVoidAsync("localStorage.removeItem", "adsumUserEmail");
    await JS.InvokeVoidAsync("localStorage.removeItem", "adsumUserNombre");

    Nav.NavigateTo("/admin", true);
}

