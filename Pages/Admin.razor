    private async Task AprobarIntencion(IntencionItem item)
    {
        try
        {
            var publicada = new Intencion
            {
                Id = string.IsNullOrWhiteSpace(item.Id) ? Guid.NewGuid().ToString() : item.Id,
                Nombre = item.Nombre,
                Texto = item.Texto,
                Fecha = item.Fecha,
                Rezos = item.Rezos
            };

            var ok = await Firebase.ActualizarObjeto(NodeIntencionesPublicadas, item.Key, publicada);

            if (ok)
            {
                await Firebase.Borrar(NodeIntencionesPendientes, item.Key);
                await Firebase.LimpiarCache(NodeIntencionesPublicadas);
                await Firebase.LimpiarCache(NodeIntencionesPendientes);
                await CargarForo(0);
            }
        }
        catch
        {
        }
    }

